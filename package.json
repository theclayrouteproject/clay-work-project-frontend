{
  "name": "clay-work-project",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:ingest": "node scripts/db-ingest.mjs",
    "db:discover": "node scripts/db-discover.mjs",
    "db:enrich": "node scripts/db-enrich-knowledge.mjs",
    "db:watch": "node scripts/db-ingest.mjs --watch",
    "db:curate": "node scripts/db-curate.mjs",
    "db:curate:audit": "node scripts/db-curate.mjs --audit",
    "market:discover": "node scripts/market-discover.mjs",
    "market:ingest": "node scripts/market-ingest.mjs",
    "market:curate": "node scripts/market-curate.mjs",
    "glaze:discover": "node scripts/glaze-discover.mjs",
    "glaze:seed:build": "node scripts/glazy-seed-build.mjs",
    "glaze:seed:build:auto": "node scripts/glazy-seed-build.mjs --auto-skip-review",
    "glaze:seed:run": "npm run glaze:seed:build && npm run glaze:ingest && npm run glaze:curate",
    "glaze:seed:run:auto": "npm run glaze:seed:build:auto && npm run glaze:ingest && npm run glaze:curate",
    "glaze:seed:run:force": "node scripts/glazy-seed-build.mjs --force && npm run glaze:ingest && npm run glaze:curate",
    "glaze:ingest": "node scripts/glaze-ingest.mjs",
    "glaze:curate": "node scripts/glaze-curate.mjs",
    "glaze:crawl": "node scripts/glazy-crawl.mjs",
    "glaze:crawl:ingest": "npm run glaze:crawl && npm run glaze:ingest && npm run glaze:curate",
    "glaze:crawler:status": "launchctl list | grep com.clayroute.glazecrawler || true",
    "glaze:crawler:install": "bash scripts/install-glaze-crawler-launchd.sh",
    "glaze:crawler:uninstall": "bash scripts/uninstall-glaze-crawler-launchd.sh",
    "glaze:discover:worker:status": "launchctl list | grep com.clayroute.glazediscovery || true",
    "glaze:discover:worker:install": "bash scripts/install-glaze-discovery-launchd.sh",
    "glaze:discover:worker:uninstall": "bash scripts/uninstall-glaze-discovery-launchd.sh",
    "glaze:pipeline:worker:status": "launchctl list | grep com.clayroute.glazepipeline || true",
    "glaze:pipeline:worker:install": "bash scripts/install-glaze-pipeline-launchd.sh",
    "glaze:pipeline:worker:uninstall": "bash scripts/uninstall-glaze-pipeline-launchd.sh",
    "market:discover:worker:status": "launchctl list | grep com.clayroute.marketdiscovery || true",
    "market:discover:worker:install": "bash scripts/install-market-discovery-launchd.sh",
    "market:discover:worker:uninstall": "bash scripts/uninstall-market-discovery-launchd.sh",
    "market:pipeline:worker:status": "launchctl list | grep com.clayroute.marketpipeline || true",
    "market:pipeline:worker:install": "bash scripts/install-market-pipeline-launchd.sh",
    "market:pipeline:worker:uninstall": "bash scripts/uninstall-market-pipeline-launchd.sh",
    "db:worker:status": "launchctl list | grep com.clayroute.dbworker || true",
    "db:worker:install": "bash scripts/install-db-worker-launchd.sh",
    "db:worker:uninstall": "bash scripts/uninstall-db-worker-launchd.sh",
    "db:discover:worker:status": "launchctl list | grep com.clayroute.dbdiscovery || true",
    "db:discover:worker:install": "bash scripts/install-db-discovery-launchd.sh",
    "db:discover:worker:uninstall": "bash scripts/uninstall-db-discovery-launchd.sh"
  },
  "dependencies": {
    "framer-motion": "^12.34.3",
    "next": "16.1.6",
    "nodemailer": "^8.0.1",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
